{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/qso-seeker/academic-contribution-bundle.schema.json",
  "title": "QSO-SEEKER Academic Contribution Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "bundle_id",
    "contribution_class",
    "title",
    "abstract",
    "software",
    "methods",
    "evidence",
    "findings",
    "limitations",
    "licenses",
    "privacy_declaration",
    "human_approved",
    "bundle_sha256"
  ],
  "properties": {
    "schema_version": {"const": "qso-academic-contribution-v1"},
    "bundle_id": {"type": "string", "minLength": 8, "maxLength": 128},
    "contribution_class": {
      "enum": ["replication_report", "dataset_contribution", "negative_result", "method_contribution", "comparative_study", "insight_report"]
    },
    "title": {"type": "string", "minLength": 1, "maxLength": 300},
    "abstract": {"type": "string", "minLength": 1, "maxLength": 5000},
    "contributors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["contributor_id"],
        "properties": {
          "contributor_id": {"type": "string"},
          "name": {"type": "string"},
          "orcid": {"type": "string"},
          "institution": {"type": "string"},
          "contact": {"type": "string"}
        }
      }
    },
    "software": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "commit_sha", "configuration_sha256"],
      "properties": {
        "repository": {"type": "string"},
        "commit_sha": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
        "configuration_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "runtime": {"type": "string"}
      }
    },
    "methods": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["evidence_type", "sha256", "redistributable"],
        "properties": {
          "evidence_type": {"type": "string"},
          "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "locator": {"type": "string"},
          "redistributable": {"type": "boolean"},
          "citation": {"type": "string"},
          "license": {"type": "string"}
        }
      }
    },
    "findings": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "limitations": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "contradictions": {"type": "array", "items": {"type": "string"}},
    "licenses": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_license", "data_license"],
      "properties": {
        "report_license": {"type": "string"},
        "data_license": {"type": "string"},
        "code_license": {"type": "string"}
      }
    },
    "privacy_declaration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contains_credentials", "contains_private_locators", "contains_personal_data", "reviewed_for_disclosure"],
      "properties": {
        "contains_credentials": {"const": false},
        "contains_private_locators": {"const": false},
        "contains_personal_data": {"type": "boolean"},
        "personal_data_authorized": {"type": "boolean"},
        "reviewed_for_disclosure": {"const": true}
      }
    },
    "human_approved": {"const": true},
    "bundle_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  }
}
