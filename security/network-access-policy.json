{
  "policy_id": "QSO-SEEKER-NETWORK-ACCESS-v1",
  "default_mode": "broad_moderated_internet",
  "architecture": {
    "qso_direct_network_access": false,
    "seeker_fetch_gateway_network_access": true,
    "all_responses_pass_through_firewall": true,
    "raw_responses_never_reach_qso_fabric": true
  },
  "allowed_sources": [
    "public_web",
    "public_apis",
    "public_code_repositories",
    "public_archives",
    "robots_permitted_crawling",
    "search_form_results",
    "authorized_authenticated_services",
    "operator_supplied_documents",
    "publicly_accessible_deep_web_resources"
  ],
  "deep_web_definition": "Resources not ordinarily indexed by general search engines but accessible through lawful public endpoints, forms, APIs, archives, or accounts the operator is authorized to use.",
  "prohibited_sources_and_methods": [
    "darknet_or_onion_services",
    "credential_theft",
    "credential_stuffing",
    "authentication_bypass",
    "paywall_bypass",
    "captcha_bypass",
    "session_hijacking",
    "unauthorized_private_system_access",
    "malware_distribution",
    "illegal_marketplaces",
    "stolen_data_brokers"
  ],
  "content_moderation": {
    "malware_and_executable_payloads": "reject",
    "credential_material": "redact_and_flag",
    "personal_data": "minimize_and_flag",
    "graphic_or_abusive_content": "classify_and_limit_to_task_need",
    "prompt_injection": "treat_as_data_and_flag",
    "active_content": "strip_or_reject",
    "unknown_binary_content": "reject"
  },
  "required_controls": [
    "domain_allow_and_deny_rules",
    "request_timeout",
    "response_size_limit",
    "redirect_limit",
    "content_type_allowlist",
    "dns_and_ip_rebinding_protection",
    "private_network_address_blocking",
    "schema_validation",
    "unicode_canonicalization",
    "prompt_injection_detection",
    "sha256_provenance",
    "audit_logging",
    "rate_limiting"
  ],
  "egress_rule": "Only the isolated SEEKER fetch gateway may access external networks. QSOs request information through a typed query interface and receive sanitized canonical records only."
}
