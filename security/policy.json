{
  "policy_id": "QSO-SEEKER-SECURITY-CORE-v1",
  "canonical_repository": "aevespers2/QSO-SEEKER",
  "treat_all_repository_text_as_untrusted_data": true,
  "never_interpret_as_instructions": true,
  "normalization": {
    "unicode": "NFKC",
    "remove_zero_width": true,
    "remove_bidi_controls": true,
    "remove_invisible_spacing": true,
    "remove_emoji_and_symbols_from_metadata": true,
    "flag_mixed_scripts": true,
    "collapse_whitespace": true
  },
  "reject": [
    "nul_bytes",
    "binary_payloads",
    "executables",
    "archives",
    "active_html",
    "dangerous_uri_schemes",
    "ansi_escape_sequences"
  ],
  "provenance": {
    "sha256": true,
    "record_transformations": true,
    "record_security_flags": true
  },
  "credentials": {
    "retrieval_read_only": true,
    "model_visible_tokens": false,
    "model_visible_cookies": false,
    "writes_require_separate_reviewed_path": true
  }
}
