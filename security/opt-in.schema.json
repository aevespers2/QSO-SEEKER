{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aevespers2/QSO-SEEKER/blob/main/security/opt-in.schema.json",
  "title": "QSO-SEEKER Repository Opt-In",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "enabled", "issue_notifications", "consent_marker"],
  "properties": {
    "schema_version": {"const": 1},
    "enabled": {"type": "boolean"},
    "issue_notifications": {"type": "boolean"},
    "consent_marker": {"const": "QSO-SEEKER-OPT-IN-v1"},
    "scan_interval_hours": {"type": "integer", "minimum": 1, "maximum": 168, "default": 24},
    "scan": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "enum": ["description", "topics", "readme", "recent_commits", "issues", "pull_requests", "release_notes", "selected_files"]
      }
    },
    "selected_files": {
      "type": "array",
      "maxItems": 100,
      "items": {"type": "string", "minLength": 1, "maxLength": 512, "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"}
    },
    "minimum_alert_score": {"type": "integer", "minimum": 1, "maximum": 100, "default": 70},
    "deduplicate_hours": {"type": "integer", "minimum": 1, "maximum": 2160, "default": 168},
    "labels": {
      "type": "array",
      "maxItems": 5,
      "items": {"type": "string", "minLength": 1, "maxLength": 50}
    },
    "contact": {"type": "string", "maxLength": 200}
  }
}
