{
  "policy_id": "QSO-SEEKER-ECOSYSTEM-SCAN-v1",
  "mode": "randomized_public_sampling",
  "coverage_claim": "No claim of complete GitHub coverage. Coverage is limited by public API availability, rate limits, repository size, and workflow runtime.",
  "target_cycle_hours": 48,
  "schedule_minutes": 30,
  "sampling": {
    "strategy": "seeded_random_walk",
    "seed_source": "workflow_run_id_and_utc_date",
    "maximum_repositories_per_run": 50,
    "maximum_records_per_repository": 20,
    "deduplicate_with_snapshot_hashes": true
  },
  "evidence": {
    "store_in_qso_seeker": true,
    "workflow_artifact": true,
    "open_local_issue_for_high_confidence_signal": true,
    "include_raw_sensitive_content": false,
    "include_repository_and_commit_links": true,
    "include_matched_heuristics": true,
    "include_sha256": true
  },
  "third_party_notification": {
    "automatic_issue_creation": false,
    "reason": "Unsolicited automated issues at ecosystem scale risk spam, false accusations, and abuse.",
    "allowed_when": [
      "repository_has_explicit_qso_seeker_opt_in_file",
      "repository_owner_is_same_authenticated_owner",
      "human_review_has_approved_the_finding"
    ]
  },
  "classification_language": {
    "allowed": ["signal", "heuristic match", "suspicious text pattern", "requires review"],
    "forbidden_without_independent_evidence": ["attack confirmed", "injection performed", "compromised repository"]
  }
}
