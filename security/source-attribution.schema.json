{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aevespers2/QSO-SEEKER/blob/main/security/source-attribution.schema.json",
  "title": "QSO-SEEKER Source Attribution Sidecar",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "source_record_sha256", "repository", "source_url", "contributors", "license", "retrieval", "sidecar_sha256"],
  "properties": {
    "schema_version": {"const": 1},
    "source_record_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "repository": {"type": "string", "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"},
    "source_url": {"type": "string", "format": "uri", "maxLength": 2000},
    "contributors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["credit_name", "role", "source"],
        "properties": {
          "credit_name": {"type": "string", "minLength": 1, "maxLength": 200},
          "role": {"type": "string", "minLength": 1, "maxLength": 120},
          "source": {"enum": ["repository_owner", "commit_author", "declared_maintainer", "artifact_metadata", "unknown"]},
          "profile_url": {"type": ["string", "null"], "format": "uri", "maxLength": 2000}
        }
      }
    },
    "license": {
      "type": "object",
      "additionalProperties": false,
      "required": ["spdx_id", "source"],
      "properties": {
        "spdx_id": {"type": ["string", "null"], "maxLength": 100},
        "source": {"enum": ["repository_api", "license_file", "package_metadata", "unknown"]}
      }
    },
    "retrieval": {
      "type": "object",
      "additionalProperties": false,
      "required": ["retrieved_at_utc", "retrieval_mode", "content_path", "commit_sha"],
      "properties": {
        "retrieved_at_utc": {"type": "string", "format": "date-time"},
        "retrieval_mode": {"enum": ["public_api", "public_raw_file", "public_archive_metadata"]},
        "content_path": {"type": "string", "minLength": 1, "maxLength": 1000},
        "commit_sha": {"type": ["string", "null"], "pattern": "^[a-fA-F0-9]{7,64}$"}
      }
    },
    "downstream_use": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "training_allowed": {"enum": ["yes", "no", "unknown", "license_dependent"]},
        "derivative_use_allowed": {"enum": ["yes", "no", "unknown", "license_dependent"]},
        "attribution_required": {"enum": ["yes", "no", "unknown", "license_dependent"]}
      }
    },
    "sidecar_sha256": {"type": "string", "pattern": "^[a-f0-9]{64}$"}
  }
}
